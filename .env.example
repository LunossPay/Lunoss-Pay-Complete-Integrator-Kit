# Lunoss Pay — Environment Variables
# Copy this file to .env and fill in your values

# API credentials
LUNOSS_API_KEY=sk_live_your_key_here

# Your Solana wallet address (receives payments)
MERCHANT_WALLET=YourSolanaWalletAddressHere

# Webhook secret (from Settings → Webhooks in the dashboard)
WEBHOOK_SECRET=your_webhook_secret_here

# API base URL (leave as production or change to local for development)
LUNOSS_BASE_URL=https://api.lunosspay.com
# LUNOSS_BASE_URL=http://localhost:3002

# Port for the webhook handler example
PORT=3001
